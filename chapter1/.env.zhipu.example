# 智谱 AI + Tavily 配置示例

# ===========================
# 智谱 AI 配置
# ===========================
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
# 新用户免费 25 元额度
API_KEY=your_zhipu_api_key_here

# API 端点（兼容 OpenAI SDK）
BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 模型选择
# 免费模型（推荐学习使用）
MODEL_ID=glm-4-flash

# 其他可选模型
# MODEL_ID=glm-4-air      # 轻量级，性价比高
# MODEL_ID=glm-4-plus     # 性能最强
# MODEL_ID=glm-4.7        # 平衡型

# ===========================
# Tavily 搜索 API 配置
# ===========================
# 获取 API Key: https://www.tavily.com/
# 免费额度: 1000 次/月
TAVILY_API_KEY=your_tavily_api_key_here
